# local-demo | local-live | staging | production
APP_PROFILE=local-demo
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=8080
PUBLIC_API_BASE_URL=http://127.0.0.1:8080
PUBLIC_DEFAULT_DOMAIN=human_otc
PUBLIC_PUSH_TO_TALK_DEFAULT=true
PUBLIC_ALWAYS_LISTENING=false
PUBLIC_SYNTHETIC_DEMO=true
VITE_REALTIME_BROKER_URL=
VITE_APP_PROFILE=local-demo

# Server only. Empty in local-demo.
OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL=gpt-5.4-mini
OPENAI_AMBIGUITY_MODEL=gpt-5.5
OPENAI_AUTHORING_MODEL=gpt-5.5
OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REASONING_DEFAULT=none
OPENAI_REASONING_AMBIGUOUS=low
OPENAI_RESPONSES_STORE=false
OPENAI_RESPONSES_TIMEOUT_MS=2500
OPENAI_MAX_OUTPUT_TOKENS=420
# Local hard guards. Restarting the API resets these in-memory counters.
OPENAI_REFINEMENT_MAX_REQUESTS_PER_HOUR=60
OPENAI_REALTIME_MAX_SESSIONS_PER_HOUR=20
OPENAI_LIVE_TESTS=false
OPENAI_SAFETY_IDENTIFIER_SECRET=

AUTH_MODE=mock-local
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URI=
DATABASE_URL=postgresql://pharmassist:change-me@127.0.0.1:5432/pharmassist
PACK_STORAGE_DRIVER=filesystem
PACK_STORAGE_PATH=./data/generated-dev-pack
PACK_SIGNING_PRIVATE_KEY_PATH=
PACK_VERIFY_PUBLIC_KEY_PATH=./config/dev-pack-public-key.pem
RAW_AUDIO_PERSIST=false
RAW_TRANSCRIPT_PERSIST=false
FREE_TEXT_LOGGING=false
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
FEATURE_LLM_REFINEMENT=false
FEATURE_REALTIME_TRANSCRIPTION=false
FEATURE_ALWAYS_LISTENING=false
