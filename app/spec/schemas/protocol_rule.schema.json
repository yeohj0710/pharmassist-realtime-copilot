{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharmassist.local/schemas/protocol_rule.schema.json",
  "title": "ProtocolRule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_id",
    "protocol_id",
    "kind",
    "operator",
    "field",
    "effect",
    "reason",
    "priority",
    "source_refs",
    "status",
    "review"
  ],
  "properties": {
    "rule_id": {
      "type": "string",
      "pattern": "^RUL-[A-Z0-9_-]+$"
    },
    "protocol_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "required_slot",
        "exclusion_pattern",
        "referral_pattern",
        "selection_pattern"
      ]
    },
    "operator": {
      "type": "string",
      "enum": [
        "present",
        "absent",
        "matches",
        "not_matches",
        "equals",
        "one_of"
      ]
    },
    "field": {
      "type": "string"
    },
    "value": {},
    "effect": {
      "type": "string",
      "enum": [
        "ask",
        "exclude",
        "refer",
        "select"
      ]
    },
    "question": {
      "type": [
        "string",
        "null"
      ]
    },
    "reason": {
      "type": "string"
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "option_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "source_id",
          "source_snapshot_id",
          "locator",
          "verified_at"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "source_snapshot_id": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "verified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "review",
        "published",
        "stale",
        "retired"
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pharmacist_approved",
        "official_source_verified"
      ],
      "properties": {
        "pharmacist_approved": {
          "type": "boolean"
        },
        "official_source_verified": {
          "type": "boolean"
        },
        "reviewer_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "reviewed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    }
  }
}
