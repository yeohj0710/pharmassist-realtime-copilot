{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharmassist.local/schemas/ingredient.schema.json",
  "title": "Ingredient",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ingredient_id",
    "display_name_ko",
    "normalized_name",
    "status",
    "source_snapshot_ids",
    "source_refs",
    "review"
  ],
  "properties": {
    "ingredient_id": {
      "type": "string",
      "pattern": "^ING-[A-Z0-9_-]+$"
    },
    "display_name_ko": {
      "type": "string",
      "minLength": 1
    },
    "display_name_en": {
      "type": [
        "string",
        "null"
      ]
    },
    "normalized_name": {
      "type": "string",
      "minLength": 1
    },
    "mfds_ingredient_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "unknown"
      ]
    },
    "source_snapshot_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "source_id",
          "source_snapshot_id",
          "locator",
          "verified_at"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "source_snapshot_id": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "verified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pharmacist_approved",
        "official_source_verified"
      ],
      "properties": {
        "pharmacist_approved": {
          "type": "boolean"
        },
        "official_source_verified": {
          "type": "boolean"
        },
        "reviewer_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "reviewed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    }
  }
}
