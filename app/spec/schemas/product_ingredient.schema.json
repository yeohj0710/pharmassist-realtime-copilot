{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharmassist.local/schemas/product_ingredient.schema.json",
  "title": "ProductIngredient",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product_ingredient_id",
    "product_id",
    "ingredient_id",
    "strength_text",
    "is_active",
    "source_refs"
  ],
  "properties": {
    "product_ingredient_id": {
      "type": "string",
      "pattern": "^PRI-[A-Z0-9_-]+$"
    },
    "product_id": {
      "type": "string"
    },
    "ingredient_id": {
      "type": "string"
    },
    "strength_text": {
      "type": "string",
      "minLength": 1
    },
    "normalized_amount": {
      "type": [
        "number",
        "null"
      ]
    },
    "normalized_unit": {
      "type": [
        "string",
        "null"
      ]
    },
    "role": {
      "type": "string",
      "enum": [
        "active",
        "excipient",
        "unknown"
      ]
    },
    "is_active": {
      "type": "boolean"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "source_id",
          "source_snapshot_id",
          "locator",
          "verified_at"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "source_snapshot_id": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "verified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
