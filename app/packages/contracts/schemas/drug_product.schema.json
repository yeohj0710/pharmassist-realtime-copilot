{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharmassist.local/schemas/drug_product.schema.json",
  "title": "DrugProduct",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product_id",
    "display_name",
    "jurisdiction",
    "item_seq",
    "otc_status",
    "status",
    "source_snapshot_ids",
    "source_refs"
  ],
  "properties": {
    "product_id": {
      "type": "string",
      "pattern": "^PRD-[A-Z0-9_-]+$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "manufacturer": {
      "type": ["string", "null"]
    },
    "jurisdiction": {
      "type": "string",
      "const": "KR"
    },
    "item_seq": {
      "type": "string",
      "minLength": 1
    },
    "permit_number": {
      "type": ["string", "null"]
    },
    "product_code": {
      "type": ["string", "null"]
    },
    "otc_status": {
      "type": "string",
      "enum": ["otc", "prescription", "unknown"]
    },
    "dosage_form": {
      "type": ["string", "null"]
    },
    "route": {
      "type": ["string", "null"]
    },
    "permit_status": {
      "type": ["string", "null"]
    },
    "supply_performance": {
      "type": "boolean"
    },
    "active_ingredients": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ingredient_id", "name", "strength_text"],
        "properties": {
          "ingredient_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "strength_text": {
            "type": "string"
          },
          "normalized_amount": {
            "type": ["number", "null"]
          },
          "normalized_unit": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "discontinued", "withdrawn", "blocked", "unknown"]
    },
    "source_snapshot_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "source_id",
          "source_snapshot_id",
          "locator",
          "verified_at"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "source_snapshot_id": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "verified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "dur_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "code", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "duplicate",
              "age",
              "pregnancy",
              "coadministration",
              "elderly",
              "dose",
              "duration",
              "split",
              "other"
            ]
          },
          "code": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "effective_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "blocking": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
