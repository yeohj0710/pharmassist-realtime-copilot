{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharmassist.local/schemas/claim.schema.json",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "claim_type",
    "subject",
    "predicate",
    "object",
    "status",
    "risk_level",
    "source_refs",
    "review"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^CLM-[A-Z0-9_-]+$"
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "indication",
        "dose",
        "administration",
        "contraindication",
        "interaction",
        "adverse_effect",
        "red_flag",
        "referral",
        "monitoring",
        "counseling_phrase",
        "workflow",
        "product_metadata"
      ]
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "predicate": {
      "type": "string",
      "minLength": 1
    },
    "object": {},
    "qualifiers": {
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "conflicted",
        "verified",
        "published",
        "stale",
        "rejected"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "moderate", "high", "critical"]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    },
    "conflict_claim_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pharmacist_approved", "official_source_verified"],
      "properties": {
        "pharmacist_approved": {
          "type": "boolean"
        },
        "official_source_verified": {
          "type": "boolean"
        },
        "reviewer_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reviewed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "locator", "trust_tier"],
      "properties": {
        "source_id": {
          "type": "string"
        },
        "locator": {
          "type": "string"
        },
        "trust_tier": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "X"]
        }
      }
    }
  }
}
