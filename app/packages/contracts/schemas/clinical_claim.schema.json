{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharmassist.local/schemas/clinical_claim.schema.json",
  "title": "ClinicalClaim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "pack_id",
    "claim_type",
    "subject_type",
    "subject_id",
    "predicate",
    "object",
    "status",
    "risk_level",
    "source_refs",
    "review"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^CLM-[A-Z0-9_-]+$"
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "indication",
        "administration",
        "contraindication",
        "interaction",
        "adverse_effect",
        "red_flag",
        "referral",
        "monitoring",
        "product_metadata",
        "workflow"
      ]
    },
    "subject_type": {
      "type": "string",
      "enum": ["ingredient", "product", "protocol", "option"]
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "predicate": {
      "type": "string",
      "minLength": 1
    },
    "object": {},
    "qualifiers": {
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "conflicted",
        "verified",
        "published",
        "stale",
        "rejected"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "moderate", "high", "critical"]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "source_id",
          "source_snapshot_id",
          "locator",
          "verified_at"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "source_snapshot_id": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "verified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "conflict_claim_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pharmacist_approved", "official_source_verified"],
      "properties": {
        "pharmacist_approved": {
          "type": "boolean"
        },
        "official_source_verified": {
          "type": "boolean"
        },
        "reviewer_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "reviewed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    }
  }
}
