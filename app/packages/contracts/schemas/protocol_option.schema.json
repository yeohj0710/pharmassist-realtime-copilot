{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharmassist.local/schemas/protocol_option.schema.json",
  "title": "ProtocolOption",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "option_id",
    "protocol_id",
    "ingredient_id",
    "display_name",
    "clinical_priority",
    "safety_priority",
    "claim_ids",
    "source_refs",
    "status",
    "review"
  ],
  "properties": {
    "option_id": {
      "type": "string",
      "pattern": "^OPT-[A-Z0-9_-]+$"
    },
    "protocol_id": {
      "type": "string"
    },
    "ingredient_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "clinical_priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "safety_priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "therapeutic_role": {
      "type": "string",
      "enum": ["preferred", "alternative", "conditional"]
    },
    "evidence_scope": {
      "type": "string",
      "enum": ["direct", "supportive", "phenotype_specific"]
    },
    "fit_rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "pathway_mechanisms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "combination_roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["primary", "supportive"]
      }
    },
    "compatible_roles": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "claim_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "eligibility_rule_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "exclusion_rule_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "source_id",
          "source_snapshot_id",
          "locator",
          "verified_at"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "source_snapshot_id": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "verified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "review", "published", "stale", "retired"]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pharmacist_approved", "official_source_verified"],
      "properties": {
        "pharmacist_approved": {
          "type": "boolean"
        },
        "official_source_verified": {
          "type": "boolean"
        },
        "reviewer_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "reviewed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    }
  }
}
