{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharmassist.local/schemas/otc_protocol.schema.json",
  "title": "OTCProtocol",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_id",
    "pack_id",
    "version",
    "domain",
    "intent",
    "symptom_category",
    "display_name",
    "status",
    "triggers",
    "option_ids",
    "rule_ids",
    "source_refs",
    "review",
    "expires_at"
  ],
  "properties": {
    "protocol_id": {
      "type": "string",
      "pattern": "^PTC-[A-Z0-9_-]+$"
    },
    "pack_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "domain": {
      "type": "string",
      "const": "human_otc"
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "symptom_category": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "review", "published", "stale", "retired"]
    },
    "triggers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchors", "aliases", "keywords"],
      "properties": {
        "anchors": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "keywords": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "negative": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "option_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "rule_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "source_id",
          "source_snapshot_id",
          "locator",
          "verified_at"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "source_snapshot_id": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "verified_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pharmacist_approved", "official_source_verified"],
      "properties": {
        "pharmacist_approved": {
          "type": "boolean"
        },
        "official_source_verified": {
          "type": "boolean"
        },
        "reviewer_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "reviewed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "expires_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
