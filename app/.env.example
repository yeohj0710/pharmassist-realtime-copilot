# local-demo | local-live | staging | production
APP_PROFILE=local-demo
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=8080
PUBLIC_API_BASE_URL=http://127.0.0.1:8080
VITE_API_BASE_URL=http://127.0.0.1:8080
VITE_REALTIME_BROKER_URL=http://127.0.0.1:8080/v1/realtime/session
PHARMASSIST_WEB_PORT=14273
PUBLIC_DEFAULT_DOMAIN=human_otc
PUBLIC_PUSH_TO_TALK_DEFAULT=true
PUBLIC_ALWAYS_LISTENING=false
PUBLIC_SYNTHETIC_DEMO=true
VITE_APP_PROFILE=local-demo

# Server only. Empty in local-demo.
OPENAI_API_KEY=
APP_PASSCODE=0903
OPENAI_RESPONSES_MODEL=gpt-5-nano
OPENAI_CONTEXT_MODEL=gpt-4.1-mini
OPENAI_AMBIGUITY_MODEL=gpt-5.4-mini
OPENAI_AUTHORING_MODEL=gpt-5.5
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_REASONING_DEFAULT=none
OPENAI_REASONING_AMBIGUOUS=low
OPENAI_RESPONSES_STORE=false
OPENAI_RESPONSES_TIMEOUT_MS=8000
OPENAI_MAX_OUTPUT_TOKENS=420
# Local hard guards. Restarting the API resets these in-memory counters.
OPENAI_REFINEMENT_MAX_REQUESTS_PER_HOUR=60
OPENAI_REALTIME_MAX_SESSIONS_PER_HOUR=20
OPENAI_LIVE_TESTS=false
FEATURE_AI_INTERPRETATION=true
OPENAI_SAFETY_IDENTIFIER_SECRET=

AUTH_MODE=mock-local
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URI=
DATABASE_URL=postgresql://pharmassist:change-me@127.0.0.1:5432/pharmassist
PACK_STORAGE_DRIVER=filesystem
PACK_STORAGE_PATH=./data/generated-dev-pack
PACK_SIGNING_PRIVATE_KEY_PATH=
PACK_VERIFY_PUBLIC_KEY_PATH=./config/dev-pack-public-key.pem
RAW_AUDIO_PERSIST=false
RAW_TRANSCRIPT_PERSIST=false
FREE_TEXT_LOGGING=false
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
FEATURE_LLM_REFINEMENT=false
FEATURE_REALTIME_TRANSCRIPTION=true
FEATURE_ALWAYS_LISTENING=false

# Server-only MFDS provider credentials. Leave empty until approved.
MFDS_EASY_DRUG_SERVICE_KEY=
MFDS_PERMIT_SERVICE_KEY=
MFDS_DUR_PRODUCT_SERVICE_KEY=
MFDS_DUR_INGREDIENT_SERVICE_KEY=
# Verify operation paths against the account-visible Swagger before activation.
MFDS_EASY_DRUG_OPERATION_PATH=getDrbEasyDrugList
MFDS_PERMIT_OPERATION_PATH=getDrugPrdtPrmsnDtlInq07
MFDS_DUR_PRODUCT_OPERATION_PATH=getDurPrdlstInfoList03
MFDS_DUR_INGREDIENT_OPERATION_PATH=getDurIrdntInfoList02
MFDS_HTTP_MAX_ATTEMPTS=4
# Private local source repository. Never expose this path to the web client.
PHARMACY_CATALOG_SOURCE_DIR=
# Health.kr remains disabled until a written contract grants every required use.
HEALTH_KR_PROVIDER_ENABLED=false
HEALTH_KR_AGREEMENT_ID=
