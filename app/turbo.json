{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": { "dependsOn": ["^build"], "outputs": ["dist/**"] },
    "typecheck": { "dependsOn": ["^build"], "outputs": [] },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["PHARMASSIST_WEB_PORT"]
    },
    "test": { "dependsOn": ["^build"], "outputs": ["coverage/**"] }
  }
}
