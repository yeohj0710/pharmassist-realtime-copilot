# Runtime profile: local-demo | local-live | staging | production
APP_PROFILE=local-demo
NODE_ENV=development

# Public web config. Never put a standard OpenAI key here.
PUBLIC_API_BASE_URL=http://localhost:8080
PUBLIC_DEFAULT_DOMAIN=human_otc
PUBLIC_PUSH_TO_TALK_DEFAULT=true
PUBLIC_ALWAYS_LISTENING=false
PUBLIC_SYNTHETIC_DEMO=true

# Server-only OpenAI config. Leave empty for local-demo.
OPENAI_API_KEY=
OPENAI_PROJECT_ID=
OPENAI_RESPONSES_MODEL=gpt-5.6-luna
OPENAI_AMBIGUITY_MODEL=gpt-5.6-terra
OPENAI_AUTHORING_MODEL=gpt-5.6-sol
OPENAI_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REASONING_DEFAULT=none
OPENAI_REASONING_AMBIGUOUS=low
OPENAI_RESPONSES_STORE=false
OPENAI_RESPONSES_TIMEOUT_MS=2500
OPENAI_MAX_OUTPUT_TOKENS=420
OPENAI_LIVE_TESTS=false
OPENAI_SAFETY_IDENTIFIER_SECRET=

# Auth. Local demo may use an explicit mock identity only on localhost.
AUTH_MODE=mock-local
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URI=

# Storage
DATABASE_URL=postgresql://pharmassist:pharmassist@localhost:5432/pharmassist
PACK_STORAGE_DRIVER=filesystem
PACK_STORAGE_PATH=./.local/packs
PACK_SIGNING_PRIVATE_KEY_PATH=
PACK_VERIFY_PUBLIC_KEY_PATH=./config/dev-pack-public-key.pem

# Privacy/observability
RAW_AUDIO_PERSIST=false
RAW_TRANSCRIPT_PERSIST=false
FREE_TEXT_LOGGING=false
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
CODED_AUDIT_RETENTION_DAYS=365

# Feature flags: secure defaults
FEATURE_TYPED_INPUT=true
FEATURE_LOCAL_OFFLINE=true
FEATURE_LLM_REFINEMENT=false
FEATURE_REALTIME_TRANSCRIPTION=false
FEATURE_PRESCRIPTION_MODE=false
FEATURE_SUPPLEMENT_MODE=false
FEATURE_ANIMAL_MODE=false
FEATURE_ALWAYS_LISTENING=false
FEATURE_RAW_AUDIO_LOGGING=false
FEATURE_RAW_TRANSCRIPT_LOGGING=false
