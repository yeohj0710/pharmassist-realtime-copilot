{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharmassist.local/schemas/pack_manifest.schema.json",
  "title": "PackManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_version",
    "schema_version",
    "min_app_version",
    "domain",
    "synthetic",
    "clinical_use_prohibited",
    "created_at",
    "expires_at",
    "counts",
    "files",
    "sha256",
    "signature"
  ],
  "properties": {
    "pack_version": { "type": "string", "minLength": 1, "maxLength": 80 },
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "min_app_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "domain": {
      "type": "string",
      "enum": [
        "human_otc",
        "prescription_counseling",
        "supplement",
        "animal_medicine"
      ]
    },
    "synthetic": { "type": "boolean" },
    "clinical_use_prohibited": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "approved_at": { "type": ["string", "null"], "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cards", "claims", "sources", "products"],
      "properties": {
        "cards": { "type": "integer", "minimum": 0 },
        "claims": { "type": "integer", "minimum": 0 },
        "sources": { "type": "integer", "minimum": 0 },
        "products": { "type": "integer", "minimum": 0 }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "pattern": "^[a-zA-Z0-9._/-]+$" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "golden_suite_version": { "type": "string" },
    "prompt_registry_version": { "type": "string" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value"],
      "properties": {
        "algorithm": { "const": "Ed25519" },
        "key_id": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "revoked_card_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^CARD-[A-Z0-9_-]+$" }
    }
  }
}
