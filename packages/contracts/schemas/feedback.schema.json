{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharmassist.local/schemas/feedback.schema.json",
  "title": "Feedback",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "sequence",
    "card_id",
    "outcome",
    "reason_codes",
    "knowledge_version",
    "latency_bucket"
  ],
  "properties": {
    "session_id": { "type": "string", "format": "uuid" },
    "sequence": { "type": "integer", "minimum": 0 },
    "card_id": { "type": "string", "pattern": "^CARD-[A-Z0-9_-]+$" },
    "outcome": {
      "type": "string",
      "enum": ["accepted", "edited", "rejected", "escalated"]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z0-9_]+$" }
    },
    "knowledge_version": { "type": "string", "maxLength": 80 },
    "latency_bucket": {
      "type": "string",
      "enum": ["0-50", "50-100", "100-250", "250-500", "500+"]
    }
  }
}
